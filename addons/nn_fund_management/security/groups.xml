<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="module_category_nn_fund_management" model="ir.module.category">
            <field name="name">NN Fund Management</field>
            <field name="description">Access rights for fund accounts, requests, approvals, and audit records.</field>
            <field name="sequence">30</field>
        </record>

        <record id="group_nn_fund_user" model="res.groups">
            <field name="name">Fund User</field>
            <field name="category_id" ref="module_category_nn_fund_management"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_nn_finance_user" model="res.groups">
            <field name="name">Finance User</field>
            <field name="category_id" ref="module_category_nn_fund_management"/>
            <field name="implied_ids" eval="[(4, ref('group_nn_fund_user'))]"/>
        </record>

        <record id="group_nn_gm_approver" model="res.groups">
            <field name="name">GM Approver</field>
            <field name="category_id" ref="module_category_nn_fund_management"/>
            <field name="implied_ids" eval="[(4, ref('group_nn_fund_user'))]"/>
        </record>

        <record id="group_nn_md_approver" model="res.groups">
            <field name="name">MD Approver</field>
            <field name="category_id" ref="module_category_nn_fund_management"/>
            <field name="implied_ids" eval="[(4, ref('group_nn_fund_user'))]"/>
        </record>

        <record id="group_nn_fund_admin" model="res.groups">
            <field name="name">Fund Administrator</field>
            <field name="category_id" ref="module_category_nn_fund_management"/>
            <field name="implied_ids" eval="[
                (4, ref('group_nn_finance_user')),
                (4, ref('group_nn_gm_approver')),
                (4, ref('group_nn_md_approver'))
            ]"/>
        </record>

        <function model="res.groups" name="write">
            <value model="res.groups" search="[('id', '=', ref('base.group_system'))]"/>
            <value eval="{'implied_ids': [(4, ref('group_nn_fund_admin'))]}"/>
        </function>

    </data>
</odoo>
