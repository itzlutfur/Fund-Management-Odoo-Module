<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- Incoming Fund Tree View -->
        <record id="view_nn_incoming_fund_tree" model="ir.ui.view">
            <field name="name">nn.incoming_fund.tree</field>
            <field name="model">nn.incoming_fund</field>
            <field name="arch" type="xml">
                <tree string="Incoming Funds">
                    <field name="name"/>
                    <field name="date"/>
                    <field name="fund_account_id"/>
                    <field name="amount" sum="Total"/>
                    <field name="state"/>
                </tree>
            </field>
        </record>

        <!-- Incoming Fund Form View -->
        <record id="view_nn_incoming_fund_form" model="ir.ui.view">
            <field name="name">nn.incoming_fund.form</field>
            <field name="model">nn.incoming_fund</field>
            <field name="arch" type="xml">
                <form string="Incoming Fund">
                    <header>
                        <button name="action_confirm" string="Confirm" type="object" class="btn-primary" invisible="state != 'draft'"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name" readonly="1"/>
                                <field name="fund_account_id" required="1"/>
                                <field name="date"/>
                            </group>
                            <group>
                                <field name="amount" required="1"/>
                                <field name="transaction_reference" required="1"/>
                                <field name="sender_source"/>
                            </group>
                        </group>
                        <group>
                            <field name="description" nolabel="1"/>
                        </group>
                        <group invisible="state != 'confirmed'">
                            <field name="confirmed_date" readonly="1"/>
                            <field name="confirmed_by" readonly="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Incoming Fund Search View -->
        <record id="view_nn_incoming_fund_search" model="ir.ui.view">
            <field name="name">nn.incoming_fund.search</field>
            <field name="model">nn.incoming_fund</field>
            <field name="arch" type="xml">
                <search string="Search Incoming Funds">
                    <field name="name"/>
                    <field name="fund_account_id"/>
                    <field name="transaction_reference"/>
                    <field name="sender_source"/>
                    <separator/>
                    <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                    <filter string="Confirmed" name="confirmed" domain="[('state','=','confirmed')]"/>
                    <separator/>
                    <filter string="This Month" name="this_month" domain="[('date','&gt;=', (context_today() - relativedelta(months=1)).strftime('%Y-%m-01')), ('date','&lt;=', context_today().strftime('%Y-%m-31'))]"/>
                </search>
            </field>
        </record>

        <!-- Incoming Fund Action -->
        <record id="action_nn_incoming_fund" model="ir.actions.act_window">
            <field name="name">Incoming Funds</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">nn.incoming_fund</field>
            <field name="view_mode">tree,form</field>
        </record>

    </data>
</odoo>
