<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- Fund Requisition Tree View -->
        <record id="view_nn_fund_requisition_tree" model="ir.ui.view">
            <field name="name">nn.fund_requisition.tree</field>
            <field name="model">nn.fund_requisition</field>
            <field name="arch" type="xml">
                <tree string="Fund Requisitions">
                    <field name="name"/>
                    <field name="requested_amount" sum="Total Requested"/>
                    <field name="remaining_billable_amount" sum="Remaining"/>
                    <field name="current_approval_level"/>
                    <field name="state"/>
                </tree>
            </field>
        </record>

        <!-- Fund Requisition Form View -->
        <record id="view_nn_fund_requisition_form" model="ir.ui.view">
            <field name="name">nn.fund_requisition.form</field>
            <field name="model">nn.fund_requisition</field>
            <field name="arch" type="xml">
                <form string="Fund Requisition">
                    <header>
                        <button name="action_submit" string="Submit" type="object" class="btn-primary" invisible="state != 'draft'"/>
                        <button name="action_approve_gm" string="Approve (GM)" type="object" class="btn-success" invisible="state != 'submitted'"/>
                        <button name="action_approve_md" string="Approve (MD)" type="object" class="btn-success" invisible="state != 'gm_approved'"/>
                        <button name="action_close" string="Close" type="object" invisible="state != 'approved'"/>
                        <button name="action_reject" string="Reject" type="object" invisible="state not in ['submitted', 'gm_approved', 'md_approved']"/>
                        <button name="action_cancel" string="Cancel" type="object" invisible="state not in ['draft', 'submitted', 'gm_approved', 'md_approved']"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,submitted,gm_approved,md_approved,approved,closed,rejected"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name" readonly="1"/>
                                <field name="requested_amount" required="1" readonly="state != 'draft'"/>
                                <field name="remaining_billable_amount" readonly="1"/>
                            </group>
                            <group>
                                <field name="request_date"/>
                                <field name="required_date"/>
                                <field name="requested_by" readonly="1"/>
                                <field name="current_approval_level" readonly="1"/>
                            </group>
                        </group>
                        <group>
                            <field name="project_id" readonly="state != 'draft'"/>
                            <field name="expense_head_id" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="purpose" nolabel="1" readonly="state != 'draft'"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Fund Requisition Search View -->
        <record id="view_nn_fund_requisition_search" model="ir.ui.view">
            <field name="name">nn.fund_requisition.search</field>
            <field name="model">nn.fund_requisition</field>
            <field name="arch" type="xml">
                <search string="Search Fund Requisitions">
                    <field name="name"/>
                    <field name="project_id"/>
                    <field name="expense_head_id"/>
                    <separator/>
                    <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                    <filter string="Pending Approval" name="pending" domain="[('state','in',['submitted','gm_approved','md_approved'])]"/>
                    <filter string="Approved" name="approved" domain="[('state','=','approved')]"/>
                    <filter string="Closed" name="closed" domain="[('state','=','closed')]"/>
                    <filter string="Rejected" name="rejected" domain="[('state','=','rejected')]"/>
                    <separator/>
                    <filter string="Pending Bills" name="pending_bills" domain="[('remaining_billable_amount','>',0)]"/>
                    <filter string="Fully Billed" name="fully_billed" domain="[('remaining_billable_amount','=',0)]"/>
                </search>
            </field>
        </record>

        <!-- Fund Requisition Action -->
        <record id="action_nn_fund_requisition" model="ir.actions.act_window">
            <field name="name">Fund Requisitions</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">nn.fund_requisition</field>
            <field name="view_mode">tree,form</field>
        </record>

    </data>
</odoo>
