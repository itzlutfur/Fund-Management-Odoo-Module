<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- Approval History Tree View -->
        <record id="view_nn_approval_history_tree" model="ir.ui.view">
            <field name="name">nn.approval_history.tree</field>
            <field name="model">nn.approval_history</field>
            <field name="arch" type="xml">
                <tree string="Approval History" create="false" delete="false">
                    <field name="request_type"/>
                    <field name="approver_id"/>
                    <field name="approval_level"/>
                    <field name="decision"/>
                    <field name="decision_date"/>
                </tree>
            </field>
        </record>

        <!-- Approval History Form View -->
        <record id="view_nn_approval_history_form" model="ir.ui.view">
            <field name="name">nn.approval_history.form</field>
            <field name="model">nn.approval_history</field>
            <field name="arch" type="xml">
                <form string="Approval History" create="false" delete="false">
                    <sheet>
                        <group>
                            <group>
                                <field name="request_type" readonly="1"/>
                                <field name="allocation_id" invisible="request_type != 'allocation'" readonly="1"/>
                                <field name="requisition_id" invisible="request_type != 'requisition'" readonly="1"/>
                                <field name="transfer_id" invisible="request_type != 'transfer'" readonly="1"/>
                            </group>
                            <group>
                                <field name="approver_id" readonly="1"/>
                                <field name="approval_level" readonly="1"/>
                                <field name="decision" readonly="1"/>
                                <field name="decision_date" readonly="1"/>
                            </group>
                        </group>
                        <group>
                            <field name="comment" nolabel="1" readonly="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Approval History Search View -->
        <record id="view_nn_approval_history_search" model="ir.ui.view">
            <field name="name">nn.approval_history.search</field>
            <field name="model">nn.approval_history</field>
            <field name="arch" type="xml">
                <search string="Search Approval History">
                    <field name="approver_id"/>
                    <field name="allocation_id"/>
                    <field name="requisition_id"/>
                    <field name="transfer_id"/>
                    <separator/>
                    <filter string="Allocation Approvals" name="allocation" domain="[('request_type','=','allocation')]"/>
                    <filter string="Requisition Approvals" name="requisition" domain="[('request_type','=','requisition')]"/>
                    <filter string="Transfer Approvals" name="transfer" domain="[('request_type','=','transfer')]"/>
                    <separator/>
                    <filter string="Approved" name="approved" domain="[('decision','=','approved')]"/>
                    <filter string="Rejected" name="rejected" domain="[('decision','=','rejected')]"/>
                    <separator/>
                    <filter string="GM Level" name="gm_level" domain="[('approval_level','=','gm')]"/>
                    <filter string="MD Level" name="md_level" domain="[('approval_level','=','md')]"/>
                </search>
            </field>
        </record>

        <!-- Approval History Action -->
        <record id="action_nn_approval_history" model="ir.actions.act_window">
            <field name="name">Approval History</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">nn.approval_history</field>
            <field name="view_mode">tree,form</field>
        </record>

    </data>
</odoo>
